modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "LongMemEval full-s run"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "LongMemEval stop-fix validation"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "LME slice eval"

[[workflows.workflow]]
name = "LongMemEval full-s run"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd longmemeval-harness && ../.pythonlibs/bin/python -u -m longmemeval_harness --size full --split s --reader sonnet --run-id full-s-sonnet --concurrency 3"

[[workflows.workflow]]
name = "LongMemEval stop-fix validation"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd longmemeval-harness && ../.pythonlibs/bin/python -u -m longmemeval_harness --size small --split s --reader sonnet --run-id pref-extract-s --limit 50 --concurrency 2 --extraction llm"

[[workflows.workflow]]
name = "LME slice eval"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd longmemeval-harness && ../.pythonlibs/bin/python -u -m longmemeval_harness --size full --split s --reader sonnet --extraction llm --retain-assistant-facts --reader-mode parity --run-id task19-retain-500 --concurrency 3"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3000

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "libxcrypt", "rustc"]
